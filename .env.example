# Docker Compose reads this file automatically when present as `.env`.
# These values control the host side of docker-compose.full.yaml.


HOLYCLAUDE_HOST_PORT=53001
GSD_HOST_PORT=53002
# GSD_DOMAIN=gsd.xxxxxx.com

# Host bind-mount paths
HOLYCLAUDE_HOST_CLAUDE_DIR=.storage/data/claude
HOLYCLAUDE_HOST_WORKSPACE_DIR=.storage/workspace
HOLYCLAUDE_HOST_CLOUDCLI_DIR=.storage/data/claudecli
HOLYCLAUDE_HOST_GSD_PROJECTS_DIR=.storage/gsd/projects