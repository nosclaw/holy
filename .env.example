# Docker Compose reads this file automatically when present as `.env`.
# These values control the host side of docker-compose.full.yaml.


HOLYCLAUDE_HOST_PORT=53001
GSD_HOST_PORT=53002
# GSD_DOMAIN=gsd.xxxxxx.com

# --- Dynamic GSD Plugin Integration ---
# Point this to a GitHub repo to automatically download and build the GSD plugin on startup.
# This allows you to stay updated with the official repository without rebuilding the image.
# GSD_PLUGIN_REPO=https://github.com/nosclaw/holy.git
# GSD_PLUGIN_SUBDIR=plugins/cloudcli-plugin-gsd

# --- gsd-pi Version Control ---
# Specify the version of gsd-pi to install on boot. 
# Set to 'latest' to always get the newest version, or a specific version like '2.54.0'.
# Set to 'none' or leave blank to skip boot-time updates.
GSD_PI_VERSION=latest

# Host bind-mount paths
HOLYCLAUDE_HOST_CLAUDE_DIR=.storage/data/claude
HOLYCLAUDE_HOST_WORKSPACE_DIR=.storage/workspace
HOLYCLAUDE_HOST_CLOUDCLI_DIR=.storage/data/claudecli
HOLYCLAUDE_HOST_GSD_PROJECTS_DIR=.storage/gsd/projects